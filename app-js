
const state = {
  data: [],
  week: 'Auto',
  category: 'All',
  license: 'All',
  search: ''
};

const refs = {
  seasonName: document.getElementById('seasonName'),
  seriesCount: document.getElementById('seriesCount'),
  entryCount: document.getElementById('entryCount'),
  weekFilter: document.getElementById('weekFilter'),
  categoryFilter: document.getElementById('categoryFilter'),
  licenseFilter: document.getElementById('licenseFilter'),
  searchInput: document.getElementById('searchInput'),
  resultMeta: document.getElementById('resultMeta'),
  cards: document.getElementById('cards'),
  resetBtn: document.getElementById('resetBtn'),
  cardTemplate: document.getElementById('cardTemplate')
};

init();

async function init() {
  const res = await fetch('./season-2026-s2.json');
  const payload = await res.json();
  state.data = payload.entries;
  refs.seasonName.textContent = payload.season;

  const categories = [...new Set(state.data.map(item => item.category))].sort();
  const licenses = ['Rookie', 'D', 'C', 'B', 'A', 'Pro/WC'].filter(value =>
    state.data.some(item => item.license === value)
  );
  const weekMap = getWeekMap(state.data);

  fillSelect(refs.categoryFilter, ['All', ...categories]);
  fillSelect(refs.licenseFilter, ['All', ...licenses], 'All');

  refs.weekFilter.innerHTML = '';
  const autoOption = document.createElement('option');
  autoOption.value = 'Auto';
  autoOption.textContent = `Auto (${getAutoWeekLabel(weekMap)})`;
  refs.weekFilter.appendChild(autoOption);
  Object.entries(weekMap)
    .sort((a, b) => Number(a[0]) - Number(b[0]))
    .forEach(([week, date]) => {
      const opt = document.createElement('option');
      opt.value = week;
      opt.textContent = `Week ${week} • ${date}`;
      refs.weekFilter.appendChild(opt);
    });

  refs.seriesCount.textContent = new Set(state.data.map(item => item.seriesName)).size.toLocaleString('ja-JP');
  refs.entryCount.textContent = state.data.length.toLocaleString('ja-JP');

  refs.weekFilter.addEventListener('change', e => { state.week = e.target.value; render(); });
  refs.categoryFilter.addEventListener('change', e => { state.category = e.target.value; render(); });
  refs.licenseFilter.addEventListener('change', e => { state.license = e.target.value; render(); });
  refs.searchInput.addEventListener('input', e => { state.search = e.target.value.trim().toLowerCase(); render(); });
  refs.resetBtn.addEventListener('click', () => {
    state.week = 'Auto';
    state.category = 'All';
    state.license = 'All';
    state.search = '';
    refs.weekFilter.value = 'Auto';
    refs.categoryFilter.value = 'All';
    refs.licenseFilter.value = 'All';
    refs.searchInput.value = '';
    render();
  });

  render();
}

function fillSelect(select, values) {
  select.innerHTML = '';
  values.forEach(value => {
    const opt = document.createElement('option');
    opt.value = value;
    opt.textContent = value;
    select.appendChild(opt);
  });
}

function getWeekMap(data) {
  const map = {};
  data.forEach(item => {
    if (!map[item.week]) map[item.week] = item.startDate;
  });
  return map;
}

function getAutoWeek(weekMap) {
  const today = new Date().toISOString().slice(0, 10);
  const weeks = Object.entries(weekMap)
    .map(([week, date]) => ({ week, date }))
    .sort((a, b) => a.date.localeCompare(b.date));

  let selected = weeks[0]?.week ?? '1';
  weeks.forEach(entry => {
    if (entry.date <= today) selected = entry.week;
  });
  return String(selected);
}

function getAutoWeekLabel(weekMap) {
  const autoWeek = getAutoWeek(weekMap);
  return `Week ${autoWeek}`;
}

function render() {
  const weekMap = getWeekMap(state.data);
  const activeWeek = state.week === 'Auto' ? getAutoWeek(weekMap) : state.week;

  let filtered = state.data.filter(item => String(item.week) === String(activeWeek));

  if (state.category !== 'All') {
    filtered = filtered.filter(item => item.category === state.category);
  }
  if (state.license !== 'All') {
    filtered = filtered.filter(item => item.license === state.license);
  }
  if (state.search) {
    filtered = filtered.filter(item =>
      item.seriesName.toLowerCase().includes(state.search) ||
      item.track.toLowerCase().includes(state.search) ||
      (item.subtitle || '').toLowerCase().includes(state.search)
    );
  }

  filtered.sort((a, b) =>
    a.category.localeCompare(b.category) ||
    a.license.localeCompare(b.license) ||
    a.seriesName.localeCompare(b.seriesName)
  );

  refs.resultMeta.textContent = `${filtered.length.toLocaleString('ja-JP')} 件表示中 / Week ${activeWeek}`;

  refs.cards.innerHTML = '';
  if (!filtered.length) {
    const empty = document.createElement('div');
    empty.className = 'empty-state card';
    empty.innerHTML = '<strong>該当する開催情報がありません。</strong><br>Week またはフィルター条件を変えてください。';
    refs.cards.appendChild(empty);
    return;
  }

  filtered.forEach(item => {
    const node = refs.cardTemplate.content.firstElementChild.cloneNode(true);
    node.querySelector('.series-name').textContent = item.seriesName;
    node.querySelector('.series-subtitle').textContent = item.subtitle || '—';
    node.querySelector('.category-badge').textContent = item.category;
    node.querySelector('.license-badge').textContent = item.license;
    node.querySelector('.week-value').textContent = `Week ${item.week}`;
    node.querySelector('.date-value').textContent = item.startDate;
    node.querySelector('.track-value').textContent = item.track;
    refs.cards.appendChild(node);
  });
}
